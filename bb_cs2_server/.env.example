# BioBase CS2 Server — Environment Configuration
# Copy to .env and adjust, or run ../install.sh to generate automatically.

# ── Server ──
CS2_SERVERNAME=Biobase CS2
CS2_RCONPW=changeme
CS2_STARTMAP=de_mirage
CS2_MAXPLAYERS=16
CS2_LAN=0
CS2_CHEATS=0

# Bot defaults (used by bots_start.sh and dashboard bot controls)
CS2_BOT_QUOTA=10
CS2_BOT_QUOTA_MODE=fill
CS2_BOT_DIFFICULTY=1

# Server profile: play (default) = combat + MatchZy; practice|kz = CS2KZ + dev cheats
BB_CS2_SERVER_PROFILE=play
BB_CS2_ENABLE_MATCHZY=1

# Steam Game Server Token — required for public listing, optional for LAN
# https://steamcommunity.com/dev/managegameservers
# SRCDS_TOKEN=

# ── Dashboard ──
BB_CS2_DASHBOARD_TOKEN=changeme
# BB_CS2_DASHBOARD_USER=
BB_DASHBOARD_ROOT_PATH=/admin
BB_DASHBOARD_COOKIE_SECURE=0

# ── Clips Storage ──
# Local directory for clip uploads. Absolute path or relative to docker-compose.yml.
BB_CLIPS_HOST_DIR=./data/clips

# ── Client Connection ──
# Hostname the BioBase desktop app uses to connect. Set to your LAN IP for local play.
BB_CS2_CONNECT_HOST=localhost
BB_CS2_CONNECT_PORT=27015
BB_CLIENT_PAIRING_CODE=BIOBASE-TRY

# ── Advanced ──
# BB_CS2_CONTROL_PORT=8765
# BB_CS2_DASHBOARD_PORT=8780
# BB_CS2_CONTROL_TOKEN=
# BB_DEMO_PARSE_MAX_MB=2048
# BB_DASHBOARD_MAX_UPLOAD_MB=2048
